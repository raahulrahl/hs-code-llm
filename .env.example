# Copy to .env (which is gitignored) and fill in real values.
# Loaded automatically by sft_phase0 / predict via python-dotenv —
# nothing else has to import dotenv directly.

# Hugging Face token — used to download Qwen + push trained adapters.
# Get one at https://huggingface.co/settings/tokens (read scope is
# enough for download; write scope if you intend to push checkpoints).
HF_TOKEN=hf_replace_me

# Weights & Biases — used by sft_phase0's training callback to log
# loss / lr / tokens-per-second per iteration to a project on wandb.ai.
# Leave WANDB_API_KEY blank to disable W&B (training prints to stdout
# only, no other behavioural change).
WANDB_API_KEY=
WANDB_PROJECT=hs-code-llm
WANDB_ENTITY=
